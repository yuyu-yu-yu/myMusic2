# Server
PORT=3000
HOST=127.0.0.1

# NetEase OpenAPI
NETEASE_BASE_URL=https://openapi.music.163.com
NETEASE_APP_ID=
NETEASE_APP_SECRET=
NETEASE_PRIVATE_KEY=
NETEASE_ACCESS_TOKEN=

# NetEase device parameters
NETEASE_DEVICE_CHANNEL=netease
NETEASE_DEVICE_ID=mymusiclocal001
NETEASE_DEVICE_TYPE=andrcar
NETEASE_DEVICE_APP_VER=6.0.0
NETEASE_DEVICE_OS=andrcar
NETEASE_DEVICE_OS_VER=14
NETEASE_DEVICE_BRAND=netease
NETEASE_DEVICE_MODEL=myMusic
NETEASE_DEVICE_CLIENT_IP=127.0.0.1
NETEASE_DEVICE_NET_STATUS=wifi
NETEASE_DEVICE_FLOW_FLAG=init

# OpenAI-compatible LLM
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# TTS. Use volcengine for Doubao/Volcengine HTTP TTS, or openai for OpenAI-compatible speech.
TTS_PROVIDER=volcengine
TTS_BASE_URL=
TTS_API_KEY=
TTS_MODEL=
TTS_VOICE=
VOLCENGINE_TTS_APP_ID=
VOLCENGINE_TTS_ACCESS_KEY=
VOLCENGINE_TTS_ACCESS_TOKEN=
VOLCENGINE_TTS_AUTH_TYPE=api-key
VOLCENGINE_TTS_VERSION=v3
VOLCENGINE_TTS_RESOURCE_ID=seed-tts-2.0
VOLCENGINE_TTS_APP_KEY=aGjiRDfUWi
VOLCENGINE_TTS_CLUSTER=volcano_tts
VOLCENGINE_TTS_VOICE_TYPE=zh_female_vv_uranus_bigtts
VOLCENGINE_TTS_ENDPOINT=https://openspeech.bytedance.com/api/v3/tts/unidirectional/sse
VOLCENGINE_TTS_SPEED_RATIO=1
VOLCENGINE_TTS_VOLUME_RATIO=1
VOLCENGINE_TTS_PITCH_RATIO=1

# Weather. Open-Meteo works without an API key.
WEATHER_PROVIDER=openmeteo
WEATHER_CITY=上海
WEATHER_COUNTRY_CODE=CN
WEATHER_API_KEY=
