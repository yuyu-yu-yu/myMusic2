# Server
PORT=3000
HOST=127.0.0.1

# NetEase OpenAPI
NETEASE_BASE_URL=https://openapi.music.163.com
NETEASE_APP_ID=
NETEASE_APP_SECRET=
NETEASE_PRIVATE_KEY=
NETEASE_ACCESS_TOKEN=

# NetEase device parameters
NETEASE_DEVICE_CHANNEL=netease
NETEASE_DEVICE_ID=mymusiclocal001
NETEASE_DEVICE_TYPE=andrcar
NETEASE_DEVICE_APP_VER=6.0.0
NETEASE_DEVICE_OS=andrcar
NETEASE_DEVICE_OS_VER=14
NETEASE_DEVICE_BRAND=netease
NETEASE_DEVICE_MODEL=myMusic
NETEASE_DEVICE_CLIENT_IP=127.0.0.1
NETEASE_DEVICE_NET_STATUS=wifi
NETEASE_DEVICE_FLOW_FLAG=init

# OpenAI-compatible LLM
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# TTS. OpenAI-compatible speech endpoint is supported when TTS_PROVIDER=openai.
TTS_PROVIDER=
TTS_BASE_URL=
TTS_API_KEY=
TTS_MODEL=
TTS_VOICE=

# Optional weather
WEATHER_CITY=
WEATHER_API_KEY=
